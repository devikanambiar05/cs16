# MongoDB
MONGO_URI=mongodb://localhost:27017/samagama

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server
PORT=5000
NODE_ENV=development

# App URL (used for email links)
APP_URL=http://localhost:5173

# SMTP (optional — emails log to console if not set)
# Format: smtps://user:password@smtp.example.com:465
# Leave empty for development (emails print to server console)
SMTP_URL=
SMTP_FROM=noreply@faqapp.local